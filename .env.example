AI_VIDEO_MODEL=gen4_turbo

# ── TTS Voice ─────────────────────────────────────────────────
EDGE_TTS_VOICE=en-US-GuyNeural

# ── Video Quality ─────────────────────────────────────────────
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
VIDEO_BITRATE=5M
