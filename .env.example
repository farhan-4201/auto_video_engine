# ── API Keys (pick at least one media provider) ───────────────
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Media providers (optional — YouTube via yt-dlp needs no key)
PIXABAY_API_KEY=
PEXELS_API_KEY=

# ── AI Video (optional — Runway Gen-4 Turbo) ──────────────────
